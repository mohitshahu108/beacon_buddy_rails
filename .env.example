# MailerSend Configuration
# Get your API key from: https://app.mailersend.com/dashboard
MAILERSEND_API_KEY=your_api_key_here

# Email sender configuration
# For local testing: Use MailerSend's sandbox domain (e.g., trial@yourdomain.mailersend.com)
# For production: Use your verified custom domain (e.g., noreply@beaconbuddy.com)
MAILERSEND_FROM_EMAIL=trial@yourdomain.mailersend.com
MAILERSEND_FROM_NAME=BeaconBuddy Team

# Email delivery method
# Options: mailersend (real emails), letter_opener (browser preview for development)
EMAIL_DELIVERY_METHOD=mailersend
